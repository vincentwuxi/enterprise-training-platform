# NexusLearn Server Environment Example

DATABASE_URL="postgresql://user:password@localhost:5432/nexuslearn?schema=public"
JWT_SECRET="nl_jwt_secret_2026_change_in_production"
JWT_EXPIRES_IN="24h"
NODE_ENV="development"
PORT=3001

# Cloudflare Access SSO Settings
# CF_TEAM_DOMAIN is the subdomain name of your Zero Trust org (e.g., "aivolo" for aivolo.cloudflareaccess.com)
CF_TEAM_DOMAIN=""
# CF_ACCESS_AUD is the Application Audience Tag found in Zero Trust app settings
CF_ACCESS_AUD=""
# ADMIN_EMAIL is the initial fallback administrator account
ADMIN_EMAIL="wenyun@gmail.com"
